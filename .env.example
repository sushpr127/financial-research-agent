# ── Copy this file to .env and fill in your keys ─────────────────────────────
# Never commit .env to git — it's in .gitignore

# LLM — get free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# News search — get free key at https://tavily.com (1000 searches/month free)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith tracing — get free key at https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=financial-research-agent
